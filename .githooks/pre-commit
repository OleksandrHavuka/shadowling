#!/bin/sh
# pre-commit — run every dev gate before the commit: ruff + tach + mypy + the test
# suite, via check.sh (one source of truth for the gates). The whole run is ~instant,
# so there's no fast/full split. A missing dev tool FAILS the gate with an install
# hint (check.sh never silently skips). Activate once per clone:
#   git config core.hooksPath .githooks
# Git runs this from the repo root; check.sh cd's to its own dir.
exec "$(git rev-parse --show-toplevel)/plugins/shadowling/check.sh"
